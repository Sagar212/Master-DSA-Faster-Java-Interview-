  "problems": {
    "climbStairs": {
      "title": "Climbing Stairs",
      "patternSubtype": "Fibonacci DP",
      "story": "Each step builds upon the previous two.",
      "template": [
        "public int climbStairs(int n) {",
        "    if (n == 1) return 1;",
        "    int first = [[1]];",
        "    int second = [[2]];",
        "    for (int i = 3; i <= n; i++) {",
        "        int third = [[first + second]];",
        "        first = [[second]];",
        "        second = [[third]];",
        "    }",
        "    return [[second]];",
        "}"
      ]
    },
    "coinChange": {
      "title": "Coin Change",
      "patternSubtype": "Unbounded Knapsack",
      "story": "Build the smallest wallet for each amount.",
      "template": [
        "public int coinChange(int[] coins, int amount) {",
        "    int[] dp = new int[amount + 1];",
        "    Arrays.fill(dp, [[amount + 1]]);",
        "    dp[0] = [[0]];",
        "    for (int i = 1; i <= amount; i++) {",
        "        for (int coin : coins) {",
        "            if (i - coin >= 0) {",
        "                dp[i] = Math.min(dp[i], [[dp[i - coin] + 1]]);",
        "            }",
        "        }",
        "    }",
        "    return dp[amount] > amount ? [[-1]] : [[dp[amount]]];",
        "}"
      ]
    },
    "houseRobber": {
      "title": "House Robber",
      "patternSubtype": "Take or Skip DP",
      "story": "To rob or not to rob?",
      "template": [
        "public int rob(int[] nums) {",
        "    int rob1 = [[0]], rob2 = [[0]];",
        "    for (int n : nums) {",
        "        int temp = Math.max([[n + rob1]], [[rob2]]);",
        "        rob1 = [[rob2]];",
        "        rob2 = [[temp]];",
        "    }",
        "    return [[rob2]];",
        "}"
      ]
    }
  }
