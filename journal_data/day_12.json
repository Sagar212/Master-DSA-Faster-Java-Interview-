  "problems": {
    "twoSum": {
      "title": "Two Sum \u2014 Active Recall",
      "patternSubtype": "HashMap Complement Lookup",
      "story": "Guest book at party. Calculate complement (need = target - nums[i]). Check map \u2192 then store.",
      "template": [
        "public static int[] solve(int[] nums, int target) {",
        "    // STEP 1 \u2014 INIT: Create the guest book",
        "    Map<Integer, Integer> seen = new [[HashMap<>()]];",
        "",
        "    // STEP 2 \u2014 LOOP: Walk through each person",
        "    for (int i = 0; i < [[nums.length]]; i++) {",
        "",
        "        // STEP 3 \u2014 CHECK: What partner do I need?",
        "        int need = [[target - nums[i]]];",
        "        if (seen.containsKey([[need]])) {",
        "            return new int[] { [[seen.get(need)]], [[i]] };",
        "        }",
        "",
        "        // STEP 4 \u2014 STORE: Sign the guest book",
        "        seen.put([[nums[i]]], [[i]]);",
        "    }",
        "",
        "    // STEP 5 \u2014 RETURN",
        "    return new int[0];",
        "}"
      ]
    },
    "groupAnagrams": {
      "title": "Group Anagrams \u2014 Active Recall",
      "patternSubtype": "HashMap Fingerprint Grouping",
      "story": "Filing cabinet. Sort word \u2192 fingerprint \u2192 file into drawer. Return all drawers.",
      "template": [
        "public static List<List<String>> solve(String[] strs) {",
        "    // STEP 1 \u2014 INIT: Create the filing cabinet",
        "    Map<String, List<String>> groups = new [[HashMap<>()]];",
        "",
        "    // STEP 2 \u2014 LOOP: Go through each word",
        "    for (String word : [[strs]]) {",
        "",
        "        // STEP 3 \u2014 FINGERPRINT: Sort the letters",
        "        char[] chars = [[word.toCharArray()]];",
        "        Arrays.sort([[chars]]);",
        "        String fingerprint = new [[String(chars)]];",
        "",
        "        // STEP 4 \u2014 STORE: File into correct drawer",
        "        if (!groups.containsKey([[fingerprint]])) {",
        "            groups.put([[fingerprint]], new ArrayList<>());",
        "        }",
        "        groups.get([[fingerprint]]).add([[word]]);",
        "    }",
        "",
        "    // STEP 5 \u2014 RETURN",
        "    return new [[ArrayList<>(groups.values())]];",
        "}"
      ]
    },
    "validSudoku": {
      "title": "Valid Sudoku \u2014 Active Recall",
      "patternSubtype": "HashSet Duplicate Detection",
      "story": "Hotel check-in. 3 guest books. boxIndex = (row/3)*3 + (col/3). Check 3 books \u2192 store in 3 books.",
      "template": [
        "public static boolean solve(char[][] board) {",
        "    // STEP 1 \u2014 INIT: Create 3 sets of guest books",
        "    Set<Character>[] rows = new HashSet[[[9]]];",
        "    Set<Character>[] cols = new HashSet[[[9]]];",
        "    Set<Character>[] boxes = new HashSet[[[9]]];",
        "    for (int i = 0; i < 9; i++) {",
        "        rows[i] = new [[HashSet<>()]];",
        "        cols[i] = new [[HashSet<>()]];",
        "        boxes[i] = new [[HashSet<>()]];",
        "    }",
        "",
        "    // STEP 2 \u2014 LOOP: Check in each guest",
        "    for (int row = 0; row < [[9]]; row++) {",
        "        for (int col = 0; col < [[9]]; col++) {",
        "            char num = board[[[row]]][[[col]]];",
        "",
        "            // STEP 3 \u2014 SKIP: Empty cells",
        "            if (num == [['.']]) continue;",
        "",
        "            // STEP 4 \u2014 BOX INDEX",
        "            int boxIndex = [[(row / 3) * 3 + (col / 3)]];",
        "",
        "            // STEP 5 \u2014 CHECK: Duplicate?",
        "            if (rows[row].contains([[num]]) || cols[col].contains([[num]]) || boxes[boxIndex].contains([[num]])) {",
        "                return [[false]];",
        "            }",
        "",
        "            // STEP 6 \u2014 STORE: Register in all 3 books",
        "            rows[[[row]]].add([[num]]);",
        "            cols[[[col]]].add([[num]]);",
        "            boxes[[[boxIndex]]].add([[num]]);",
        "        }",
        "    }",
        "",
        "    // STEP 7 \u2014 RETURN",
        "    return [[true]];",
        "}"
      ]
    },
    "subarraySum": {
      "title": "Subarray Sum Equals K \u2014 Active Recall",
      "patternSubtype": "HashMap Prefix Sum",
      "story": "Road walk logbook. Seed (0,1). At each step: runningSum += num. Check logbook for runningSum - k.",
      "template": [
        "public static int solve(int[] nums, int k) {",
        "    int count = [[0]];",
        "    int runningSum = [[0]];",
        "",
        "    // STEP 1 \u2014 INIT: Create logbook",
        "    Map<Integer, Integer> logbook = new [[HashMap<>()]];",
        "",
        "    // STEP 2 \u2014 SEED: Critical! Distance 0 seen 1 time",
        "    logbook.put([[0]], [[1]]);",
        "",
        "    // STEP 3 \u2014 LOOP: Walk the road",
        "    for (int num : [[nums]]) {",
        "        runningSum += [[num]];",
        "",
        "        // STEP 4 \u2014 CHECK: Gap = runningSum - k",
        "        if (logbook.containsKey([[runningSum - k]])) {",
        "            count += logbook.get([[runningSum - k]]);",
        "        }",
        "",
        "        // STEP 5 \u2014 STORE: Record this milestone",
        "        logbook.put([[runningSum]], logbook.getOrDefault([[runningSum]], 0) + 1);",
        "    }",
        "",
        "    // STEP 6 \u2014 RETURN",
        "    return [[count]];",
        "}"
      ]
    }
  }
}