      "story": "VIP bouncer throws out the smallest.",
      "description": "Trace the Min-Heap keeping the Top K elements.",
      "code": [
        "public int findKthLargest(int[] nums, int k) {",
        "    PriorityQueue<Integer> minHeap = new PriorityQueue<>();",
        "    for (int num : nums) {",
        "        minHeap.offer(num);",
        "        if (minHeap.size() > k) {",
        "            minHeap.poll();",
        "        }",
        "    }",
        "    return minHeap.peek();",
        "}"
