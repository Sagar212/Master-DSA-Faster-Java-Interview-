        "num": 1,
        "text": "public int findKthLargest(int[] nums, int k) {"
      },
      {
        "num": 2,
        "text": "    // STEP 1 - INIT: Min-heap to store Top K"
      },
      {
        "num": 3,
        "text": "    PriorityQueue<Integer> minHeap = new PriorityQueue<>();"
      },
      {
        "num": 4,
        "text": ""
      },
      {
        "num": 5,
        "text": "    // STEP 2 - LOOP: Stream elements"
      },
      {
        "num": 6,
        "text": "    for (int num : nums) {"
      },
      {
        "num": 7,
        "text": "        minHeap.offer(num);"
      },
      {
        "num": 8,
        "text": "        // STEP 3 - EJECT: Keep size exactly K"
      },
      {
        "num": 9,
        "text": "        if (minHeap.size() > k) {"
      },
      {
        "num": 10,
        "text": "            minHeap.poll();"
      },
      {
        "num": 11,
        "text": "        }"
      },
      {
        "num": 12,
        "text": "    }"
      },
      {
        "num": 13,
        "text": "    // STEP 4 - RETURN: Top is Kth largest"
      },
      {
        "num": 14,
        "text": "    return minHeap.peek();"
      },
      {
        "num": 15,
        "text": "}"
      }
