  "problems": {
    "mergeIntervals": {
      "title": "Merge Intervals — Active Recall",
      "patternSubtype": "Intervals",
      "story": "Sort by start times, then merge if current end >= next start.",
      "template": [
        "public static int[][] solve(int[][] intervals) {",
        "    if (intervals.length <= 1) return intervals;",
        "    ",
        "    // Sort by start times",
        "    Arrays.sort(intervals, (a, b) -> [[Integer.compare(a[0], b[0])]]);",
        "    ",
        "    List<int[]> res = new ArrayList<>();",
        "    int[] current = intervals[0];",
        "    res.add(current);",
        "    ",
        "    for (int[] interval : intervals) {",
        "        // Check for overlap",
        "        if (current[1] >= [[interval[0]]]) {",
        "            current[1] = [[Math.max(current[1], interval[1])]];",
        "        } else {",
        "            current = [[interval]];",
        "            res.add([[current]]);",
        "        }",
        "    }",
        "    ",
        "    return res.toArray(new int[[[res.size()]]][]);",
        "}"
      ]
    },
    "insertInterval": {
      "title": "Insert Interval — Active Recall",
      "patternSubtype": "Intervals",
      "story": "Add strictly before, merge overlapping, add strictly after.",
      "template": [
        "public static int[][] solve(int[][] intervals, int[] newInterval) {",
        "    List<int[]> res = new ArrayList<>();",
        "    int i = 0, n = intervals.length;",
        "    ",
        "    // Add strictly before",
        "    while (i < n && [[intervals[i][1] < newInterval[0]]]) {",
        "        res.add(intervals[i++]);",
        "    }",
        "    ",
        "    // Merge overlapping",
        "    while (i < n && [[intervals[i][0] <= newInterval[1]]]) {",
        "        newInterval[0] = [[Math.min(newInterval[0], intervals[i][0])]];",
        "        newInterval[1] = [[Math.max(newInterval[1], intervals[i][1])]];",
        "        i++;",
        "    }",
        "    res.add([[newInterval]]);",
        "    ",
        "    // Add strictly after",
        "    while (i < n) {",
        "        res.add([[intervals[i++]]]);",
        "    }",
        "    ",
        "    return res.toArray(new int[[[res.size()]]][]);",
        "}"
      ]
    },
    "meetingRoomsII": {
      "title": "Meeting Rooms II — Active Recall",
      "patternSubtype": "Intervals",
      "story": "Separate starts and ends. Two pointers. If start < end, need a room. Else, room freed.",
      "template": [
        "public static int solve(int[][] intervals) {",
        "    int[] starts = new int[intervals.length];",
        "    int[] ends = new int[intervals.length];",
        "    for (int i = 0; i < intervals.length; i++) {",
        "        starts[i] = [[intervals[i][0]]];",
        "        ends[i] = [[intervals[i][1]]];",
        "    }",
        "    ",
        "    Arrays.sort([[starts]]);",
        "    Arrays.sort([[ends]]);",
        "    ",
        "    int rooms = 0, maxRooms = 0, s = 0, e = 0;",
        "    while (s < intervals.length) {",
        "        if ([[starts[s] < ends[e]]]) {",
        "            [[rooms++]];",
        "            [[s++]];",
        "            maxRooms = Math.max(maxRooms, rooms);",
        "        } else {",
        "            [[rooms--]];",
        "            [[e++]];",
        "        }",
        "    }",
        "    return [[maxRooms]];",
        "}"
      ]
    }
  }
}
