      "code": [
        "class Solution {",
        "    public int orangesRotting(int[][] grid) {",
        "        Queue<int[]> q = new LinkedList<>();",
        "        int fresh = 0;",
        "        for (int i = 0; i < grid.length; i++) {",
        "            for (int j = 0; j < grid[0].length; j++) {",
        "                if (grid[i][j] == 2) q.offer(new int[]{i, j});",
        "                else if (grid[i][j] == 1) fresh++;",
        "            }",
        "        }",
        "        if (fresh == 0) return 0;",
        "        int minutes = 0;",
        "        int[][] dirs = {{1,0},{-1,0},{0,1},{0,-1}};",
        "        while (!q.isEmpty()) {",
        "            int size = q.size();",
        "            boolean rotted = false;",
        "            for (int i = 0; i < size; i++) {",
        "                int[] curr = q.poll();",
        "                for (int[] d : dirs) {",
        "                    int r = curr[0] + d[0], c = curr[1] + d[1];",
        "                    if (r >= 0 && r < grid.length && c >= 0 && c < grid[0].length && grid[r][c] == 1) {",
        "                        grid[r][c] = 2;",
        "                        q.offer(new int[]{r, c});",
        "                        fresh--;",
        "                        rotted = true;",
        "                    }",
        "                }",
        "            }",
        "            if (rotted) minutes++;",
        "        }",
        "        return fresh == 0 ? minutes : -1;",
        "    }",
        "}"
      ],
      "steps": [
        {
          "line": -1,
          "desc": "Initialize queue `q` with all initially rotten oranges (2) and count `fresh` oranges."
        },
        {
          "line": -1,
          "desc": "If `fresh == 0`, return 0."
        },
        {
          "line": -1,
          "desc": "Initialize `minutes = 0` and direction array `dirs`."
        },
        {
          "line": -1,
          "desc": "While `q` is not empty, iterate through the current level (size of `q`)."
        },
        {
          "line": -1,
          "desc": "For each polled cell, check 4 directions."
        },
        {
          "line": -1,
          "desc": "If a fresh orange is found, rot it (set to 2), add to `q`, decrement `fresh`, set `rotted = true`."
        },
