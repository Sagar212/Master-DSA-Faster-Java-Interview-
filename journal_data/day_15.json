{
  "id": 15,
  "title": "Heap (PQ) \u2014 Active Recall",
  "patternType": "heap",
  "category": "Heap (PQ)",
  "oneSentence": "Fill in the blank active recall templates.",
  "problems": {
    "topK": {
      "title": "Top K Elements \u2014 Active Recall",
      "patternSubtype": "Min-Heap",
      "story": "Maintain K largest items.",
      "template": [
        "public int findKthLargest(int[] nums, int k) {",
        "    PriorityQueue<Integer> minHeap = new [[PriorityQueue<>()]];",
        "    for (int num : [[nums]]) {",
        "        minHeap.[[offer]](num);",
        "        if (minHeap.size() > [[k]]) {",
        "            minHeap.[[poll]]();",
        "        }",
        "    }",
        "    return minHeap.[[peek]]();",
        "}"
      ]
    }
  }
}